# ALSA config for ReSpeaker 2-Mic HAT (WM8960)
# Enables dmix so multiple apps can share the audio device.
# Installed to ~/.asoundrc by update.sh

pcm.!default {
    type asym
    playback.pcm "speaker"
    capture.pcm "mic"
}

pcm.speaker {
    type plug
    slave.pcm "dmixer"
}

pcm.mic {
    type plug
    slave.pcm "hw:seeed2micvoicec,0"
}

pcm.dmixer {
    type dmix
    ipc_key 1024
    ipc_perm 0666
    slave {
        pcm "hw:seeed2micvoicec,0"
        period_time 0
        period_size 1024
        buffer_size 4096
        rate 48000
        channels 2
    }
}

ctl.!default {
    type hw
    card seeed2micvoicec
}
